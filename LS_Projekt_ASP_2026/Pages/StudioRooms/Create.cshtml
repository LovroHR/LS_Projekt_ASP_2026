@page
@model LS_Projekt_ASP_2026.Pages.StudioRooms.CreateModel
@{
    ViewData["Title"] = "Dodaj studijski prostor";
}

<div class="container mt-4">
    <h2>Dodaj studijski prostor</h2>
    <form method="post">
        <div class="mb-3">
            <label class="form-label">Ime</label>
            <input asp-for="NewRoom.Name" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Lokacija</label>
            <input asp-for="NewRoom.Location" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Kapacitet</label>
            <input asp-for="NewRoom.Capacity" type="number" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Cijena/h</label>
            <input asp-for="NewRoom.HourlyPrice" type="number" step="0.01" class="form-control" />
        </div>
        <button class="btn btn-primary" type="submit">Spremi</button>
        <a class="btn btn-secondary" href="/StudioRooms/Index">Nazad</a>
    </form>
</div>
