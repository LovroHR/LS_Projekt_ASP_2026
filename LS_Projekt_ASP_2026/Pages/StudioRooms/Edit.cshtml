@page
@model LS_Projekt_ASP_2026.Pages.StudioRooms.EditModel
@{
    ViewData["Title"] = "Uredi studijski prostor";
}

<div class="container mt-4">
    <h2>Uredi studijski prostor</h2>
    <form method="post">
        <input type="hidden" asp-for="Room.Id" />
        <div class="mb-3">
            <label class="form-label">Ime</label>
            <input asp-for="Room.Name" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Lokacija</label>
            <input asp-for="Room.Location" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Kapacitet</label>
            <input asp-for="Room.Capacity" type="number" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Cijena/h</label>
            <input asp-for="Room.HourlyPrice" type="number" step="0.01" class="form-control" />
        </div>
        <button class="btn btn-primary" type="submit">Spremi</button>
        <a class="btn btn-secondary" href="/StudioRooms/Index">Nazad</a>
    </form>
</div>
