@page
@model RegisterModel
@{
    ViewData["Title"] = "Registracija";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-lg border-0" style="background: rgba(31, 41, 55, 0.9); border: 1px solid rgba(124, 58, 237, 0.2) !important;">
                <div class="card-header" style="background: linear-gradient(135deg, #7C3AED, #6366F1); border-bottom: 2px solid rgba(6, 182, 212, 0.3);">
                    <h3 class="mb-0 text-white fw-bold" style="font-family: var(--font-primary); font-size: var(--fs-h3); font-weight: var(--fw-bold); letter-spacing: var(--ls-tight);">📝 Registracija</h3>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="background: rgba(236, 72, 153, 0.1); border: 1px solid rgba(236, 72, 153, 0.5); color: #FCA5A5;">
                            <strong style="font-weight: var(--fw-bold);">Greška!</strong> <span style="font-weight: var(--fw-normal); line-height: var(--lh-normal);">@Model.ErrorMessage</span>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert" style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.5); color: #A7F3D0;">
                            <strong style="font-weight: var(--fw-bold);">Uspješno!</strong> <span style="font-weight: var(--fw-normal); line-height: var(--lh-normal);">@Model.SuccessMessage</span>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form method="post">
                        <!-- Ime i Prezime -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold" style="color: #D1D5DB; font-weight: var(--fw-semibold); font-size: var(--fs-body-sm);">👤 Ime</label>
                                <input type="text" class="form-control form-control-lg" asp-for="Name" 
                                       placeholder="Unesi ime" required style="background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(124, 58, 237, 0.3); color: #F3F4F6; font-family: var(--font-primary);">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold" style="color: #D1D5DB; font-weight: var(--fw-semibold); font-size: var(--fs-body-sm);">👤 Prezime</label>
                                <input type="text" class="form-control form-control-lg" asp-for="Surname" 
                                       placeholder="Unesi prezime" required style="background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(124, 58, 237, 0.3); color: #F3F4F6; font-family: var(--font-primary);">
                            </div>
                        </div>

                        <!-- Email -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold" style="color: #D1D5DB; font-weight: var(--fw-semibold); font-size: var(--fs-body-sm);">📧 Email Adresa</label>
                            <input type="email" class="form-control form-control-lg" asp-for="Email" 
                                   placeholder="Unesi email" required style="background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(124, 58, 237, 0.3); color: #F3F4F6; font-family: var(--font-primary);">
                            <small class="text-muted" style="font-size: var(--fs-tiny); color: var(--text-secondary);">Koristi se za prijavu</small>
                        </div>

                        <!-- Lozinka -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold" style="color: #D1D5DB; font-weight: var(--fw-semibold); font-size: var(--fs-body-sm);">🔑 Lozinka</label>
                                <input type="password" class="form-control form-control-lg" asp-for="Password" 
                                       placeholder="Najmanje 6 znakova" required style="background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(124, 58, 237, 0.3); color: #F3F4F6; font-family: var(--font-primary);">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold" style="color: #D1D5DB; font-weight: var(--fw-semibold); font-size: var(--fs-body-sm);">🔑 Potvrdi Lozinku</label>
                                <input type="password" class="form-control form-control-lg" asp-for="ConfirmPassword" 
                                       placeholder="Ponovi lozinku" required style="background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(124, 58, 237, 0.3); color: #F3F4F6; font-family: var(--font-primary);">
                            </div>
                        </div>

                        <!-- Datum Rođenja -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold" style="color: #D1D5DB; font-weight: var(--fw-semibold); font-size: var(--fs-body-sm);">🎂 Datum Rođenja</label>
                            <input type="date" class="form-control form-control-lg" asp-for="DateOfBirth" required style="background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(124, 58, 237, 0.3); color: #F3F4F6; font-family: var(--font-primary);">
                        </div>

                        <!-- Broj Telefona -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold" style="color: #D1D5DB; font-weight: var(--fw-semibold); font-size: var(--fs-body-sm);">📱 Broj Telefona</label>
                            <input type="tel" class="form-control form-control-lg" asp-for="PhoneNumber" 
                                   placeholder="+385 1 1234 5678" required style="background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(124, 58, 237, 0.3); color: #F3F4F6; font-family: var(--font-primary);">
                        </div>

                        <!-- Adresa -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold" style="color: #D1D5DB; font-weight: var(--fw-semibold); font-size: var(--fs-body-sm);">🏠 Adresa</label>
                            <input type="text" class="form-control form-control-lg" asp-for="Address" 
                                   placeholder="Ulica i broj" required style="background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(124, 58, 237, 0.3); color: #F3F4F6; font-family: var(--font-primary);">
                        </div>

                        <!-- Država -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold" style="color: #D1D5DB; font-weight: var(--fw-semibold); font-size: var(--fs-body-sm);">🌍 Država</label>
                            <select class="form-select form-select-lg" asp-for="Country" required style="background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(124, 58, 237, 0.3); color: #F3F4F6; font-family: var(--font-primary);">
                                <option value="">Odaberi državu...</option>
                                <option value="Hrvatska">Hrvatska</option>
                                <option value="Srbija">Srbija</option>
                                <option value="Bosna i Hercegovina">Bosna i Hercegovina</option>
                                <option value="Slovenija">Slovenija</option>
                                <option value="Italija">Italija</option>
                                <option value="Njemačka">Njemačka</option>
                                <option value="Francuska">Francuska</option>
                                <option value="Austrija">Austrija</option>
                                <option value="Švicarska">Švicarska</option>
                                <option value="Mađarska">Mađarska</option>
                                <option value="Češka">Češka</option>
                                <option value="Ostalo">Ostalo</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-lg w-100 fw-semibold mb-3" style="background: linear-gradient(135deg, #7C3AED, #6366F1); border: none; color: white; font-weight: var(--fw-semibold); letter-spacing: var(--ls-wide);">
                            ✓ Registriraj se
                        </button>
                    </form>

                    <hr class="my-3" style="border-color: rgba(124, 58, 237, 0.2);">

                    <div class="text-center">
                        <p class="text-muted mb-2" style="font-size: var(--fs-body-sm); color: var(--text-secondary);">Već imaš račun?</p>
                        <a href="/Auth/Login" class="btn btn-outline-light btn-lg w-100 fw-semibold" style="border: 2px solid rgba(6, 182, 212, 0.5); color: #06B6D4; font-weight: var(--fw-semibold); letter-spacing: var(--ls-wide);">
                            🔐 Prijava
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
