@page
@model LS_Projekt_ASP_2026.Pages.Bookings.CreateModel
@using AudioProductionManagement.Model
@{
    ViewData["Title"] = "Nova rezervacija";
}

<div class="container mt-4 page-shell">
    <h2>Nova rezervacija</h2>
    <form method="post" class="row g-3">
        <div asp-validation-summary="All" class="text-danger mb-2"></div>
        <div class="col-md-6">
            <label class="form-label">Početak</label>
            @await Html.PartialAsync("_DateTimePicker", new { Name = "Input.StartTime", Value = Model.Input?.StartTime, Placeholder = "Početak", ShowTime = true })
            <span asp-validation-for="Input.StartTime" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Kraj</label>
            @await Html.PartialAsync("_DateTimePicker", new { Name = "Input.EndTime", Value = Model.Input?.EndTime, Placeholder = "Kraj", ShowTime = true })
            <span asp-validation-for="Input.EndTime" class="text-danger small"></span>
        </div>
        <div class="col-md-6"><label class="form-label">Status</label><select asp-for="Input.Status" class="form-select" asp-items="Html.GetEnumSelectList<BookingStatus>()"></select></div>
        <div class="col-md-6"><label class="form-label">Cijena</label><input asp-for="Input.TotalPrice" class="form-control" type="number" step="0.01" /></div>
        <div class="col-md-12"><label class="form-label">Svrha</label><input asp-for="Input.Purpose" class="form-control" /></div>
        <div class="col-md-4">
            <label class="form-label">Klijent</label>
            <div class="autocomplete-field" data-autocomplete-source="/api/lookups/clients" data-autocomplete-mode="entity" data-autocomplete-min-length="1">
                <input type="hidden" asp-for="Input.ClientId" class="autocomplete-value" />
                <button type="button" class="btn btn-outline-light form-select autocomplete-toggle" data-placeholder="Odaberi klijenta">@(!string.IsNullOrWhiteSpace(Model.SelectedClientLabel) ? Model.SelectedClientLabel : "Odaberi klijenta")</button>
                <div class="autocomplete-menu w-100">
                    <input type="text" class="form-control autocomplete-search" placeholder="Pretraži klijenta..." autocomplete="off" />
                    <div class="autocomplete-results"></div>
                </div>
            </div>
            <span asp-validation-for="Input.ClientId" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label class="form-label">Producent</label>
            <div class="autocomplete-field" data-autocomplete-source="/api/lookups/producers" data-autocomplete-mode="entity" data-autocomplete-min-length="1">
                <input type="hidden" asp-for="Input.ProducerId" class="autocomplete-value" />
                <button type="button" class="btn btn-outline-light form-select autocomplete-toggle" data-placeholder="Odaberi producenta">@(!string.IsNullOrWhiteSpace(Model.SelectedProducerLabel) ? Model.SelectedProducerLabel : "Odaberi producenta")</button>
                <div class="autocomplete-menu w-100">
                    <input type="text" class="form-control autocomplete-search" placeholder="Pretraži producenta..." autocomplete="off" />
                    <div class="autocomplete-results"></div>
                </div>
            </div>
            <span asp-validation-for="Input.ProducerId" class="text-danger small"></span>
        </div>
        <div class="col-md-4"><label class="form-label">Studio</label><select asp-for="Input.StudioRoomId" class="form-select">@foreach (var s in Model.AvailableStudios) { <option value="@s.Id">@s.Name</option> }</select></div>
        <div class="col-md-12 form-check ms-2"><input asp-for="Input.RequiresEngineer" class="form-check-input" /><label class="form-check-label">Potreban inženjer</label></div>
        <div class="col-md-12"><label class="form-label">Napomene</label><textarea asp-for="Input.AdditionalNotes" class="form-control" rows="4"></textarea></div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Spremi</button>
            <a class="btn btn-secondary" href="/Bookings/Index">Nazad</a>
        </div>
    </form>
</div>
