@page
@model CreateModel
@{
    ViewData["Title"] = "Nova Rezervacija";
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div>
                <a href="/Bookings/Index" class="text-decoration-none">📅 Moji Studijski Termini</a> / 
                <span class="text-muted">Nova Rezervacija</span>
            </div>
            <h1 class="display-6 mt-2">✨ Nova Studijska Rezervacija</h1>
            <p class="text-muted">Rezerviraj termin i konfigurira pojedinosti</p>
        </div>
    </div>

    <!-- Main 2-Column Layout -->
    <div class="row g-4">
        <!-- LEFT COLUMN: Vrijeme Odabir (70%) -->
        <div class="col-lg-8">
            <form method="post">
                <!-- Section 1: Brzi Odabir -->
                <div class="card mb-4 border-0 shadow-sm">
                    <div class="card-header bg-light border-0">
                        <h5 class="mb-0">🎯 Odaberi Studio i Vrijeme</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Studio Prostorija</label>
                                <select class="form-select form-select-lg" id="studioSelect">
                                    <option selected disabled>Odaberi studio...</option>
                                    <option value="1">🎵 Recording Studio A</option>
                                    <option value="2">🎸 Production Studio B</option>
                                    <option value="3">🎤 Podcast Studio C</option>
                                </select>
                                <small class="text-muted">Sadrži 16-track mixing desk, Neumann mics, Pro Tools HD</small>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Producent / Inženjer</label>
                                <select class="form-select form-select-lg" id="producerSelect">
                                    <option selected disabled>Odaberi producenta...</option>
                                    <option value="1">Filip Marković - Pop & Electronic</option>
                                    <option value="2">Juraj Horvat - Heavy Rock & Metal</option>
                                    <option value="3">Ana Kovač - Podcast & Voice</option>
                                </select>
                            </div>
                        </div>

                        <div class="mt-3">
                            <button type="button" class="btn btn-outline-primary w-100" id="loadAvailability">
                                <i class="bi bi-arrow-repeat"></i> Učitaj Dostupnost
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Section 2: Kalendar -->
                <div class="card mb-4 border-0 shadow-sm">
                    <div class="card-header bg-light border-0">
                        <h5 class="mb-0">📆 Odaberi Datum</h5>
                    </div>
                    <div class="card-body">
                        <!-- Calendar Legend -->
                        <div class="mb-3">
                            <div class="d-flex gap-3 flex-wrap">
                                <div>
                                    <span class="badge bg-primary">Dostupno</span>
                                </div>
                                <div>
                                    <span class="badge bg-secondary">Zauzeto</span>
                                </div>
                                <div>
                                    <span class="badge bg-warning text-dark">Malo dostupnog</span>
                                </div>
                            </div>
                        </div>

                        <!-- Date Picker -->
                        <div class="mb-3">
                            <input type="date" class="form-control form-control-lg" id="dateInput">
                        </div>

                        <!-- Mini Calendar (Next 30 Days) -->
                        <div class="p-3 bg-light rounded">
                            <div class="row g-2">
                                @for (int i = 1; i <= 30; i++)
                                {
                                    string dayClass = i % 3 == 0 ? "secondary" : i % 5 == 0 ? "warning text-dark" : "primary";
                                    <div class="col-2">
                                        <button type="button" class="btn btn-sm btn-@dayClass w-100" style="font-size: 0.875rem;">
                                            @i
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section 3: Timeline - Satni Slotovi -->
                <div class="card mb-4 border-0 shadow-sm">
                    <div class="card-header bg-light border-0">
                        <h5 class="mb-0">⏰ Dostupni Vremenski Slotovi</h5>
                        <small class="text-muted">Odabrani datum: <strong id="selectedDateDisplay">-</strong></small>
                    </div>
                    <div class="card-body">
                        <div class="timeline-container">
                            <!-- Timeline Slotovi -->
                            @for (int h = 9; h < 22; h++)
                            {
                                string timeDisplay = h + ":00";
                                bool isAvailable = h % 2 == 0; // Demo: parni satovi dostupni
                                string slotClass = isAvailable ? "available" : "unavailable";
                                
                                <div class="timeline-slot mb-2">
                                    <div class="row align-items-center">
                                        <div class="col-2">
                                            <strong>@timeDisplay</strong>
                                        </div>
                                        <div class="col-10">
                                            <button type="button" 
                                                    class="btn btn-timeline w-100 @(isAvailable ? "btn-outline-success" : "btn-outline-secondary disabled")"
                                                    @(isAvailable ? "" : "disabled")>
                                                @if (isAvailable)
                                                {
                                                    <span>✓ Dostupno - Klikni za odabir</span>
                                                }
                                                else
                                                {
                                                    <span>✗ Zauzeto</span>
                                                }
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="alert alert-info mt-3 mb-0">
                            <i class="bi bi-info-circle"></i>
                            <strong>Savjet:</strong> Najčešće korištene sesije su 2-4 sata. Vidjeti trebaju biti dostupne prije i nakon.
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <!-- RIGHT COLUMN: Booking Forma (30%) -->
        <div class="col-lg-4">
            <div class="sticky-top" style="top: 20px;">
                <!-- Summary Card -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Sažetak Rezervacije</h5>
                    </div>
                    <div class="card-body">
                        <!-- Selected Details (Read-Only) -->
                        <div class="mb-3">
                            <small class="text-muted">Studio</small>
                            <div class="fw-semibold" id="summaryStudio">-</div>
                        </div>

                        <div class="mb-3">
                            <small class="text-muted">Datum</small>
                            <div class="fw-semibold" id="summaryDate">-</div>
                        </div>

                        <div class="mb-3">
                            <small class="text-muted">Vrijeme</small>
                            <div class="fw-semibold" id="summaryTime">-</div>
                        </div>

                        <div class="mb-3">
                            <small class="text-muted">Trajanje</small>
                            <div class="fw-semibold" id="summaryDuration">-</div>
                        </div>

                        <div class="mb-3 pb-3 border-bottom">
                            <small class="text-muted">Cijena / Sat</small>
                            <div class="fw-semibold" id="summaryRate">-</div>
                        </div>

                        <div class="alert alert-light">
                            <small class="text-muted">Ukupna Cijena</small>
                            <div class="display-6" id="summaryTotal">-</div>
                        </div>
                    </div>
                </div>

                <!-- Booking Details Form -->
                <form method="post">
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-light border-0">
                            <h5 class="mb-0">📋 Detalji Rezervacije</h5>
                        </div>
                        <div class="card-body">
                            <!-- Projekt -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Projekt</label>
                                <select class="form-select" id="projectSelect">
                                    <option selected disabled>Odaberi projekt...</option>
                                    <option value="1">Marina's Dreams - Album</option>
                                    <option value="2">Heavy Thunder - Album</option>
                                    <option value="3">Business Talk - Podcast</option>
                                    <option value="new">+ Kreiraj Novi Projekt</option>
                                </select>
                            </div>

                            <!-- Tip Projekta -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Tip Projekta</label>
                                <div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="projectType" id="typeAlbum" value="album">
                                        <label class="form-check-label" for="typeAlbum">Album</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="projectType" id="typeSingle" value="single">
                                        <label class="form-check-label" for="typeSingle">Single</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="projectType" id="typePodcast" value="podcast">
                                        <label class="form-check-label" for="typePodcast">Podcast</label>
                                    </div>
                                </div>
                            </div>

                            <hr>

                            <!-- Dodatne Opcije -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Dodatne Opcije</label>

                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="cateringCheck">
                                    <label class="form-check-label" for="cateringCheck">
                                        Catering (+50€)
                                    </label>
                                </div>

                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="techAssistantCheck">
                                    <label class="form-check-label" for="techAssistantCheck">
                                        Tehnički asistent (+100€/h)
                                    </label>
                                </div>

                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="instrumentsCheck">
                                    <label class="form-check-label" for="instrumentsCheck">
                                        Specijalni instrumenti
                                    </label>
                                </div>
                            </div>

                            <!-- Napomene -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Napomene / Specijalni Zahtjevi</label>
                                <textarea class="form-control" id="notesTextarea" rows="4" 
                                    placeholder="Objasni specifične zahtjeve, reference glazbe, specijalne potrebe..."></textarea>
                                <small class="text-muted">Max 500 znakova</small>
                            </div>

                            <!-- Terms & Conditions -->
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="termsCheck">
                                <label class="form-check-label" for="termsCheck">
                                    Prihvaćam <a href="#">Uvjete korištenja</a> i Politiku privatnosti
                                </label>
                            </div>

                            <!-- Action Buttons -->
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="bi bi-check-circle"></i> Potvrdi Rezervaciju
                                </button>
                                <a href="/Bookings" class="btn btn-outline-secondary">Odustani</a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Custom CSS za Timeline -->
<style>
    .timeline-slot {
        padding: 0.5rem 0;
        border-left: 3px solid #e9ecef;
        padding-left: 1rem;
    }

    .timeline-slot .btn-timeline {
        transition: all 0.2s ease;
    }

    .timeline-slot .btn-timeline:not(:disabled):hover {
        transform: translateX(5px);
    }

    .sticky-top {
        z-index: 10;
    }

    .btn-primary {
        background-color: #007bff;
    }

    .btn-primary:hover {
        background-color: #0056b3;
    }
</style>

<!-- JavaScript -->
<script>
    // Ažuriranje datuma iz date inputa
    document.getElementById('dateInput').addEventListener('change', function () {
        const date = new Date(this.value);
        const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
        document.getElementById('selectedDateDisplay').innerText = date.toLocaleDateString('hr-HR', options);
        document.getElementById('summaryDate').innerText = date.toLocaleDateString('hr-HR', options);
    });

    // Demo: Simulacija odabira vremena
    document.querySelectorAll('.btn-timeline:not(:disabled)').forEach(btn => {
        btn.addEventListener('click', function (e) {
            e.preventDefault();
            // Ažuriranje sažetka
            document.getElementById('summaryTime').innerText = this.textContent.trim();
        });
    });

    // Učitavanje dostupnosti (demo)
    document.getElementById('loadAvailability').addEventListener('click', function () {
        alert('Demo: Dostupnost će se učitati iz baze podataka');
    });
</script>
