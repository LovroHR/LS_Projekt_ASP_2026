@page
@model LS_Projekt_ASP_2026.Pages.Bookings.IndexModel
@{
    ViewData["Title"] = "Rezervacije";
}

<div class="container-fluid mt-4">
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info">@TempData["Message"]</div>
    }

    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h1 class="display-6 fw-bold" style="font-size: var(--fs-h1); color: var(--text-primary);">Rezervacije</h1>
            <p class="text-muted fw-normal" style="font-size: var(--fs-body-sm); color: var(--text-secondary);">Lista rezervacija s AJAX pretragom</p>
        </div>
        <div class="col-md-4 text-end">
            <a class="btn btn-primary" href="/Bookings/Create">Nova rezervacija</a>
        </div>
    </div>

    <div class="mb-3">
        <input id="searchBox" type="text" class="form-control" placeholder="Pretraži po nazivu, klijentu, producentu ili studiju..." value="@Model.Q" />
    </div>

    <div id="tableWrap" class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Termin</th>
                    <th>Studio</th>
                    <th>Klijent</th>
                    <th>Producent</th>
                    <th>Status</th>
                    <th>Cijena</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model.Bookings)
                {
                    <tr>
                        <td>@booking.StartTime.ToString("g") - @(booking.StartTime.Date == booking.EndTime.Date ? booking.EndTime.ToString("t") : booking.EndTime.ToString("g"))</td>
                        <td>@booking.StudioRoom?.Name</td>
                        <td>@booking.Client?.Name @booking.Client?.Surname</td>
                        <td>@booking.Producer?.Name @booking.Producer?.Surname</td>
                        <td>@booking.Status</td>
                        <td>@booking.TotalPrice.ToString("C")</td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" href="/Bookings/Details?id=@booking.Id">Detalji</a>
                            <a class="btn btn-sm btn-outline-secondary" href="/Bookings/Edit?id=@booking.Id">Uredi</a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@booking.Id" style="display:inline;" onsubmit="return confirm('Obrisati rezervaciju?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Obriši</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div id="emptyState" class="text-center py-5" style="display:@(Model.Bookings.Count==0 ? "block" : "none")">
        <div class="display-1 mb-3">📭</div>
        <h3>Nema rezervacija</h3>
        <p class="text-muted">Kreiraj prvu rezervaciju.</p>
        <a class="btn btn-primary" href="/Bookings/Create">Nova rezervacija</a>
    </div>
</div>

@section Scripts {
    <script>
        const searchBox = document.getElementById('searchBox');
        const tableWrap = document.getElementById('tableWrap');
        const emptyState = document.getElementById('emptyState');
        let timer = null;

        searchBox.addEventListener('input', function () {
            clearTimeout(timer);
            timer = setTimeout(() => loadBookings(searchBox.value), 250);
        });

        async function loadBookings(q) {
            const url = new URL(window.location.href);
            url.searchParams.set('handler', 'Data');
            url.searchParams.set('q', q || '');
            const response = await fetch(url.toString(), { headers: { 'Accept': 'application/json' } });
            if (!response.ok) return;
            const data = await response.json();
            const rows = data.map(b => `
                <tr>
                    <td>${formatDateRange(b.startTime, b.endTime)}</td>
                    <td>${escapeHtml(b.studioName || '')}</td>
                    <td>${escapeHtml(b.clientName || '')}</td>
                    <td>${escapeHtml(b.producerName || '')}</td>
                    <td>${escapeHtml(b.status)}</td>
                    <td>${Number(b.totalPrice).toLocaleString(undefined, { style: 'currency', currency: 'EUR' })}</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" href="/Bookings/Details?id=${b.id}">Detalji</a>
                        <a class="btn btn-sm btn-outline-secondary" href="/Bookings/Edit?id=${b.id}">Uredi</a>
                        <form method="post" action="?handler=Delete&id=${b.id}" style="display:inline;" onsubmit="return confirm('Obrisati rezervaciju?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Obriši</button>
                        </form>
                    </td>
                </tr>
            `).join('');
            tableWrap.querySelector('tbody').innerHTML = rows;
            emptyState.style.display = data.length === 0 ? 'block' : 'none';
        }

        function formatDateRange(start, end) {
            const s = new Date(start);
            const e = new Date(end);
            const sameDay = s.toDateString() === e.toDateString();
            const dateFormatter = new Intl.DateTimeFormat(undefined, { dateStyle: 'medium', timeStyle: 'short' });
            const timeFormatter = new Intl.DateTimeFormat(undefined, { timeStyle: 'short' });

            if (sameDay) {
                return `${dateFormatter.format(s)} - ${timeFormatter.format(e)}`;
            }

            return `${dateFormatter.format(s)} - ${dateFormatter.format(e)}`;
        }

        function escapeHtml(str) {
            if (!str) return '';
            return String(str).replace(/[&<>"']/g, s => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[s]));
        }
    </script>
}
