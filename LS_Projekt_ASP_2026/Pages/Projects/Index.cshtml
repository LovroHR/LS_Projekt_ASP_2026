@page
@model LS_Projekt_ASP_2026.Pages.Projects.IndexModel
@{
    ViewData["Title"] = "Projekti";
}

<div class="container-fluid mt-4">
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info">@TempData["Message"]</div>
    }

    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h1 class="display-6 fw-bold" style="font-size: var(--fs-h1); color: var(--text-primary);">Projekti</h1>
            <p class="text-muted fw-normal" style="font-size: var(--fs-body-sm); color: var(--text-secondary);">Lista projekata s AJAX pretragom</p>
        </div>
        <div class="col-md-4 text-end">
            <a class="btn btn-primary" href="/Projects/Create">Novi projekt</a>
        </div>
    </div>

    <div class="mb-3">
        <input id="searchBox" type="text" class="form-control" placeholder="Pretraži po nazivu, žanru ili osobi..." value="@Model.Q" />
    </div>

    <div id="tableWrap" class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Naziv</th>
                    <th>Tip</th>
                    <th>Status</th>
                    <th>Klijent</th>
                    <th>Producent</th>
                    <th>Budžet</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in Model.Projects)
                {
                    <tr>
                        <td>@project.Title</td>
                        <td>@project.Type</td>
                        <td>@project.Status</td>
                        <td>@project.Client?.Name @project.Client?.Surname</td>
                        <td>@project.Producer?.Name @project.Producer?.Surname</td>
                        <td>@project.Budget.ToString("C")</td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" href="/Projects/Details?id=@project.Id">Detalji</a>
                            <a class="btn btn-sm btn-outline-secondary" href="/Projects/Edit?id=@project.Id">Uredi</a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@project.Id" style="display:inline;" onsubmit="return confirm('Obrisati projekt?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Obriši</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div id="emptyState" class="text-center py-5" style="display:@(Model.Projects.Count==0 ? "block" : "none")">
        <div class="display-1 mb-3">🎼</div>
        <h3>Nema projekata</h3>
        <p class="text-muted">Kreiraj prvi projekt.</p>
        <a class="btn btn-primary" href="/Projects/Create">Novi projekt</a>
    </div>
</div>

@section Scripts {
    <script>
        const searchBox = document.getElementById('searchBox');
        const tableWrap = document.getElementById('tableWrap');
        const emptyState = document.getElementById('emptyState');
        let timer = null;

        searchBox.addEventListener('input', function () {
            clearTimeout(timer);
            timer = setTimeout(() => loadProjects(searchBox.value), 250);
        });

        async function loadProjects(q) {
            const url = new URL(window.location.href);
            url.searchParams.set('handler', 'Data');
            url.searchParams.set('q', q || '');
            const response = await fetch(url.toString(), { headers: { 'Accept': 'application/json' } });
            if (!response.ok) return;
            const data = await response.json();
            const rows = data.map(p => `
                <tr>
                    <td>${escapeHtml(p.title)}</td>
                    <td>${escapeHtml(p.type)}</td>
                    <td>${escapeHtml(p.status)}</td>
                    <td>${escapeHtml(p.clientName || '')}</td>
                    <td>${escapeHtml(p.producerName || '')}</td>
                    <td>${Number(p.budget).toLocaleString(undefined, { style: 'currency', currency: 'EUR' })}</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" href="/Projects/Details?id=${p.id}">Detalji</a>
                        <a class="btn btn-sm btn-outline-secondary" href="/Projects/Edit?id=${p.id}">Uredi</a>
                        <form method="post" action="?handler=Delete&id=${p.id}" style="display:inline;" onsubmit="return confirm('Obrisati projekt?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Obriši</button>
                        </form>
                    </td>
                </tr>
            `).join('');
            tableWrap.querySelector('tbody').innerHTML = rows;
            emptyState.style.display = data.length === 0 ? 'block' : 'none';
        }

        function escapeHtml(str) {
            if (!str) return '';
            return String(str).replace(/[&<>"']/g, s => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[s]));
        }
    </script>
}
